{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "乘风连接器",
  "version": "0.1.0",
  "identifier": "com.chengfeng.connector",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "title": "乘风连接器",
        "width": 420,
        "height": 580,
        "resizable": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/bin/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
